{
  "cli": {
    "version": ">= 16.0.0",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://toch-backend-production.up.railway.app"
      }
    },
    "preview": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://toch-backend-production.up.railway.app",
        "EXPO_PUBLIC_DEMO_MODE": "true"
      }
    },
    "review": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://toch-backend-production.up.railway.app"
      }
    },
    "production": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://toch-backend-production.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
